# Copiá este archivo como .env y completá los valores reales

# PostgreSQL — copiá la connection string de Supabase
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# Supabase — para el storage de fotos de perfil
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_SERVICE_KEY=eyJ...  # Settings > API > service_role key (secret)

# JWT — generá uno aleatorio largo, ej: openssl rand -hex 64
JWT_SECRET=cambia_esto_por_algo_muy_secreto_y_largo

# Resend — tu API key de resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx

# El dominio desde donde mandás los emails (verificado en Resend)
EMAIL_FROM=oracion@tudominio.com

# URL del frontend (para los links de invitación)
FRONTEND_URL=https://tu-app.vercel.app

# Puerto local
PORT=3000
